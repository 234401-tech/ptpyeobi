# 여비뚝딱 백엔드 환경변수 예시 — 복사해서 .env 로 사용

# SQLite 파일 경로 (프로젝트 루트의 data/ 폴더 기준)
DATABASE_URL=sqlite:///../data/여비뚝딱.db

# 업로드 원본 저장 경로
UPLOAD_DIR=../data/uploads

# CORS 허용 오리진 (콤마 구분)
CORS_ORIGINS=http://localhost:5173

# ── 오파넷(한국석유공사 Opinet) 유가 API ──
OPINET_API_KEY=
OPINET_PRODCD=B027

# ── OCR 어댑터 선택: mock | upstage | clova | claude_vision | local ──
OCR_PROVIDER=mock
UPSTAGE_API_KEY=
CLOVA_API_KEY=
CLOVA_INVOKE_URL=
ANTHROPIC_API_KEY=
